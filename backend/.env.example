# App
PORT=4000
JWT_SECRET=replace-with-strong-secret

# Comma-separated list of allowed origins in production
# Example: https://miet-curriculum.vercel.app,https://your-custom-domain.com
CORS_ORIGIN=http://localhost:5173

# SQLite file path
# Local dev example:
# DB_PATH=./data/curriculum.db
# Render disk example:
# DB_PATH=/var/data/curriculum.db
DB_PATH=./data/curriculum.db
